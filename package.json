{
  "name": "moneyforward-collector",
  "version": "3.0.0",
  "description": "Export MoneyForward deposit/withdrawal statements in CSV and take a screenshot.",
  "homepage": "https://github.com/book000/moneyforward-collector",
  "bugs": {
    "url": "https://github.com/book000/moneyforward-collector/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:book000/moneyforward-collector.git",
    "type": "git"
  },
  "scripts": {
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "fix": "run-z fix:prettier,fix:eslint",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.16.11",
    "@book000/node-utils": "1.24.292",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.9.5",
    "puppeteer-core": "25.3.0",
    "run-z": "2.1.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
