{
  "name": "moneyforward-collector",
  "version": "3.0.0",
  "description": "Export MoneyForward deposit/withdrawal statements in CSV and take a screenshot.",
  "homepage": "https://github.com/book000/moneyforward-collector",
  "bugs": {
    "url": "https://github.com/book000/moneyforward-collector/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:book000/moneyforward-collector.git",
    "type": "git"
  },
  "scripts": {
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "fix": "run-z fix:prettier,fix:eslint",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.17",
    "@book000/node-utils": "1.24.140",
    "@types/node": "24.12.2",
    "eslint": "10.2.1",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.2.1",
    "prettier": "3.8.3",
    "puppeteer-core": "24.42.0",
    "run-z": "2.1.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
